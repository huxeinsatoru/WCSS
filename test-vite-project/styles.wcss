.button {
  padding: 1rem;
  background: #3b82f6;
  color: white;
  border-radius: 0.5rem;
  font-size: 1rem;
}

.button:hover {
  background: #2563eb;
}

.card {
  padding: 2rem;
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 0.5rem;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1rem;
}

