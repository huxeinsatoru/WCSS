{
  "name": "euis-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "CSS compiler built with Rust and WebAssembly",
  "repository": {
    "type": "git",
    "url": "https://github.com/huxeinsatoru/Euis.git"
  },
  "keywords": [
    "css",
    "compiler",
    "rust",
    "wasm",
    "webassembly",
    "build-tool"
  ],
  "author": "Huxeinsatoru",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:rust": "cargo build --release",
    "build:wasm": "wasm-pack build crates/euis-wasm --target bundler --out-dir ../../pkg/bundler",
    "build:wasm:nodejs": "wasm-pack build crates/euis-wasm --target nodejs --out-dir ../../pkg/nodejs",
    "test:rust": "cargo test",
    "build:cli": "cd packages/euis-cli && npm run build",
    "build:vite": "cd packages/vite-plugin-euis && npm run build",
    "build:webpack": "cd packages/euis-loader && npm run build",
    "build:next": "cd packages/next-euis && npm run build",
    "build:nuxt": "cd packages/nuxt-euis && npm run build",
    "build:cdn": "cd packages/euis-cdn && npm run build",
    "build:vscode": "cd packages/vscode-euis && npm run build",
    "build:plugin": "npm run build:vite",
    "build": "npm run build:wasm && npm run build:plugin",
    "build:all": "npm run build:rust && npm run build:cli && npm run build:vite && npm run build:webpack && npm run build:next && npm run build:cdn",
    "publish:wasm": "cd pkg/bundler && npm publish --access public",
    "publish:plugin": "cd packages/vite-plugin-euis && npm publish --access public",
    "test": "cargo test && cd packages/euis-cli && npm test"
  },
  "devDependencies": {
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
