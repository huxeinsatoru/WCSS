{
  "name": "vscode-wcss",
  "displayName": "WCSS Language Support",
  "description": "Syntax highlighting, IntelliSense, and error reporting for WCSS files",
  "version": "0.1.0",
  "publisher": "wcss",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "wcss",
    "css",
    "styling"
  ],
  "activationEvents": [
    "onLanguage:wcss"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "wcss",
        "aliases": [
          "WCSS",
          "wcss"
        ],
        "extensions": [
          ".wcss"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wcss",
        "scopeName": "source.wcss",
        "path": "./syntaxes/wcss.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "wcss.format",
        "title": "Format WCSS",
        "category": "WCSS"
      }
    ],
    "configuration": {
      "title": "WCSS",
      "properties": {
        "wcss.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Format WCSS files on save"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.2",
    "vsce": "^2.15.0"
  }
}
